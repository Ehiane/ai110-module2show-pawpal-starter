classDiagram
    %% Enums
    class PriorityLevel {
        <<enum>>
        HIGH
        MEDIUM
        LOW
    }

    class Frequency {
        <<enum>>
        ONCE
        DAILY
        WEEKLY
        MONTHLY
    }

    %% Core Domain Classes
    class Task {
        +str description
        +datetime time
        +PriorityLevel priority
        +Frequency frequency
        +int duration
        +Pet pet
        +Dict owner_preferences
        +bool is_completed
        +UUID task_id
        +Schedule schedule
        +get_task_time() datetime
        +get_priority_level() PriorityLevel
        +get_owner_preferences() Dict
        +get_task_duration() int
        +get_end_time() datetime
        +get_description() str
        +get_frequency() Frequency
        +get_pet() Pet
        +mark_completed() void
        +mark_incomplete() void
        +is_task_completed() bool
    }

    class Pet {
        +str name
        +str breed
        +int age
        +Owner owner
        +UUID pet_id
        +get_owner() Owner
        +get_name() str
        +get_breed() str
        +get_age() int
        +get_tasks() List[Task]
        +get_pending_tasks() List[Task]
        +get_completed_tasks() List[Task]
    }

    class Schedule {
        +Pet pet
        +List~Task~ tasks
        +UUID schedule_id
        +get_tasks() List[Task]
        +add_task(Task) void
        +remove_task(Task) void
        +get_pet() Pet
        +get_tasks_by_priority(PriorityLevel) List[Task]
        +get_pending_tasks() List[Task]
    }

    class Owner {
        +str name
        +List~Pet~ pets
        +List~Schedule~ schedules
        +UUID owner_id
        +get_pets() List[Pet]
        +add_pet(Pet) void
        +remove_pet(Pet) void
        +get_tasks() List[Task]
        +get_tasks_by_priority(PriorityLevel) List[Task]
        +get_tasks_for_pet(Pet) List[Task]
        +get_owner_id() UUID
        +get_name() str
        +add_schedule(Schedule) void
        +get_all_pending_tasks() List[Task]
        +get_all_completed_tasks() List[Task]
    }

    class Scheduler {
        +List~Owner~ owners
        +add_owner(Owner) void
        +remove_owner(Owner) void
        +get_all_tasks() List[Task]
        +get_all_tasks_for_owner(Owner) List[Task]
        +get_pending_tasks_for_owner(Owner) List[Task]
        +get_completed_tasks_for_owner(Owner) List[Task]
        +get_tasks_by_priority_for_owner(Owner, PriorityLevel) List[Task]
        +get_tasks_for_pet(Pet) List[Task]
        +get_pending_tasks_for_pet(Pet) List[Task]
        +get_completed_tasks_for_pet(Pet) List[Task]
        +get_tasks_by_frequency(Frequency) List[Task]
        +get_tasks_sorted_by_priority(List~Task~) List[Task]
        +get_tasks_sorted_by_time(List~Task~) List[Task]
        +get_overdue_tasks(datetime) List[Task]
        +get_upcoming_tasks(int) List[Task]
        +find_conflicts_for_owner(Owner) List[Tuple[Task,Task]]
        +query_tasks(List~Task~) TaskQuery
        +mark_task_completed(Task) void
    }

    class TaskQuery {
        +List~Task~ tasks
        +__init__(List~Task~) void
        +filter_by_pet(Pet) TaskQuery
        +filter_by_status(str) TaskQuery
        +filter_by_priority(PriorityLevel) TaskQuery
        +sort_by(str) TaskQuery
        +limit(int) List[Task]
        +get_results() List[Task]
    }

    %% Algorithmic Functions
    class Algorithms {
        <<utility>>
        {static} has_conflict(Task, Task) bool
        {static} expand_recurring_task(Task, int) List[Task]
        {static} find_all_conflicts(List~Task~) List[Tuple[Task,Task]]
        {static} sort_by_time(List~Task~) List[Task]
    }

    %% Relationships
    Task --> Pet : references
    Task --> Schedule : belongs to
    Task --> PriorityLevel : uses
    Task --> Frequency : uses

    Pet --> Owner : owned by
    Schedule --> Pet : for
    Schedule --> Task : contains
    Owner --> Pet : owns
    Owner --> Schedule : manages

    Scheduler --> Owner : manages
    Scheduler --> Task : queries
    Scheduler --> TaskQuery : creates
    TaskQuery --> Task : filters/sorts

    Algorithms --> Task : operates on
    Algorithms --> has_conflict : implements
    Algorithms --> expand_recurring_task : implements
    Algorithms --> find_all_conflicts : implements
    Algorithms --> sort_by_time : implements
